<% layout("/layouts/boilerplate") %>

<div class="container py-5">

  <!-- Listing Section -->
  <div class="row justify-content-center">
    <div class="col-lg-8">

      <div class="card border-0 bg-transparent shadow-none">

        <!-- Title -->
        <h3 class="fw-bold text-center mb-3">
          <%= listing.title %>
        </h3>

        <!-- Image -->
        <img src="<%= listing.image.url %>" 
             class="card-img-top show-image rounded" 
             alt="listing-image">

        <div class="card-body text-center">

          <!-- Owner -->
          <p class="text-start mb-3">
            Owned by @<i><%= listing.owner.username %></i>
          </p>

          <!-- Description -->
          <p class="text-muted px-3">
            <%= listing.description %>
          </p>

          <!-- Details -->
          <ul class="list-group list-group-flush mb-4 bg-transparent">
            <li class="list-group-item bg-transparent border-0">
              <b>Price:</b> ₹ <%= listing.price.toLocaleString("en-IN") %>
            </li>
            <li class="list-group-item bg-transparent border-0">
              <b>Location:</b> <%= listing.location %>
            </li>
            <li class="list-group-item bg-transparent border-0">
              <b>Country:</b> <%= listing.country %>
            </li>
          </ul>

          <% if(currUser && currUser._id.equals(listing.owner._id)) { %>
          <div class="d-flex justify-content-center gap-3">
            <a class="btn btn-success px-4"
               href="/listings/<%= listing._id %>/edit">
              Edit
            </a>

            <form method="POST" action="/listings/<%= listing._id %>?_method=DELETE">
              <button class="btn btn-danger px-4">
                Delete
              </button>
            </form>
          </div>
          <% } %>

        </div>
      </div>

    </div>
  </div>
</div>

<hr/>

<% if(currUser) { %>
<!-- Review Form -->
<div class="row justify-content-center mt-5">
  <div class="col-lg-6">

    <div class="card border-0 shadow-sm p-4">

      <h4 class="text-center fw-bold mb-4">Leave a Review</h4>

      <form action="/listings/<%= listing._id %>/reviews" 
            method="POST" 
            novalidate 
            class="needs-validation">

        <!-- Rating -->
        <div class="mb-4">
          <label class="form-label">Rating</label>

          <fieldset class="starability-basic">
            <input type="radio" id="rate1" name="review[rating]" value="1" />
            <label for="rate1">1 star</label>

            <input type="radio" id="rate2" name="review[rating]" value="2" />
            <label for="rate2">2 stars</label>

            <input type="radio" id="rate3" name="review[rating]" value="3" />
            <label for="rate3">3 stars</label>

            <input type="radio" id="rate4" name="review[rating]" value="4" />
            <label for="rate4">4 stars</label>

            <input type="radio" id="rate5" name="review[rating]" value="5" checked />
            <label for="rate5">5 stars</label>
          </fieldset>
        </div>

        <!-- Comment -->
        <div class="mb-4">
          <label for="comment" class="form-label">Comments</label>
          <textarea class="form-control" 
                    name="review[comment]" 
                    id="comment" 
                    rows="4" 
                    required></textarea>

          <div class="invalid-feedback">
            Please add some comments
          </div>
        </div>

        <!-- Submit -->
        <div class="text-center">
          <button class="btn btn-primary px-4">Submit</button>
        </div>

      </form>

    </div>
  </div>
</div>
<% } %>

<!-- Reviews Section -->
<div class="container mt-5">
  <h4 class="fw-bold mb-4 text-center">All Reviews</h4>

  <div class="row g-3">

    <% if (listing.reviews && listing.reviews.length > 0) { %>

      <% for (let review of listing.reviews) { %>

        <div class="col-12 col-sm-6 col-md-4">
          <div class="card review-card h-100 p-3 d-flex flex-column">

            <!-- User -->
            <h6 class="fw-semibold mb-1 text-dark">
              @<%= review.author.username %>
            </h6>

            <!-- Stars -->
            <p class="starability-result small-stars mb-2" data-rating="<%= review.rating %>"></p>

            <!-- Comment -->
            <p class="text-muted small flex-grow-1 mb-2">
              <span class="short-text">
                <%= review.comment.slice(0, 100) %>
              </span>

              <span class="full-text d-none">
                <%= review.comment %>
              </span>

              <% if (review.comment.length > 100) { %>
                <span class="show-toggle text-decoration-underline fw-semibold ms-1">
                  Show more
                </span>
              <% } %>
            </p>

            <!-- Delete -->
            <% if(currUser && currUser._id.equals(review.author._id)) { %>
              <form method="POST" 
                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                <button class="btn btn-outline-danger btn-sm mt-auto">
                  Delete
                </button>
              </form>
            <% } %>

          </div>
        </div>

      <% } %>

    <% } else { %>

      <p class="text-center text-muted">No reviews yet</p>

    <% } %>

  </div>
</div>

<style>
  /* Clean review card */
.review-card {
  border: none;
  border-radius: 10px;
  transition: all 0.2s ease;
}

.review-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 4px 15px rgba(0,0,0,0.08);
}

/* Smaller stars */
.small-stars {
  font-size: 13px;
  color: #000 !important;
}

.small-stars::before {
  letter-spacing: 1.5px;
}

/* Show more */
.show-toggle {
  cursor: pointer;
}
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {
  document.querySelectorAll(".show-toggle").forEach(btn => {
    btn.addEventListener("click", () => {

      const card = btn.closest(".card");
      const shortText = card.querySelector(".short-text");
      const fullText = card.querySelector(".full-text");

      if (fullText.classList.contains("d-none")) {
        fullText.classList.remove("d-none");
        shortText.classList.add("d-none");
        btn.textContent = " Show less";
      } else {
        fullText.classList.add("d-none");
        shortText.classList.remove("d-none");
        btn.textContent = " Show more";
      }

    });
  });
});
</script>