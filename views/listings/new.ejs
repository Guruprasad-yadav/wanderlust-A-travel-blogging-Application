<%- layout("/layouts/boilerplate.ejs") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6 col-md-8">

      <!-- Card -->
      <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

        <!-- Gradient Header -->
        <div class="text-white py-4 rounded-top-4">
          <h2 class="text-center text-dark fw-bold mb-0">
            <i class="fas fa-plus me-2"></i>Create Listing
          </h2>
        </div>

        <!-- Form Body -->
        <div class="card-body p-4 p-lg-5">

          <form method="POST"
                action="/listings"
                class="needs-validation"
                novalidate
                enctype="multipart/form-data">

            <!-- Title -->
            <div class="mb-4">
              <div class="form-floating">
                <input name="listing[title]"
                       class="form-control form-control-lg"
                       id="titleInput"
                       type="text"
                       placeholder="Title"
                       required>
                <label for="titleInput">Listing Title</label>
              </div>
            </div>

            <!-- Description -->
            <div class="mb-4">
              <div class="form-floating">
                <textarea name="listing[description]"
                          class="form-control"
                          id="descInput"
                          style="min-height: 120px;"
                          placeholder="Description"
                          required></textarea>
                <label for="descInput">Description</label>
              </div>
            </div>

            <!-- Image Upload -->
            <div class="mb-4">
              <div class="form-floating">
                <input name="listing[image]"
                       class="form-control"
                       id="imageInput"
                       type="file"
                       required>
                <label for="imageInput">Upload Image</label>
              </div>
            </div>

            <!-- Price + Country -->
            <div class="row g-4 mb-4">

              <div class="col-md-5">
                <div class="form-floating">
                  <input name="listing[price]"
                         class="form-control form-control-lg"
                         id="priceInput"
                         type="number"
                         placeholder="Price"
                         required>
                  <label for="priceInput">₹ Price</label>
                </div>
              </div>

              <div class="col-md-7">
                <div class="form-floating">
                  <input name="listing[country]"
                         class="form-control form-control-lg"
                         id="countryInput"
                         type="text"
                         placeholder="Country"
                         required>
                  <label for="countryInput">Country</label>
                </div>
              </div>

            </div>

            <!-- Location -->
            <div class="mb-5">
              <div class="form-floating">
                <input name="listing[location]"
                       class="form-control form-control-lg"
                       id="locationInput"
                       type="text"
                       placeholder="Location"
                       required>
                <label for="locationInput">Location</label>
              </div>
            </div>

            <!-- Submit Button -->
            <div class="d-grid">
              <button type="submit"
                      class="btn btn-dark btn-lg rounded-pill py-3 shadow-lg"
                      style="border: none;
                             font-weight: 600;
                             font-size: 1.1rem;
                             transition: all 0.3s ease;">
                <i class="fas fa-plus me-2"></i>Add Listing
              </button>
            </div>

          </form>

        </div>
      </div>

    </div>
  </div>
</div>

