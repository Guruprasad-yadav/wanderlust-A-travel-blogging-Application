<% layout("/layouts/boilerplate") %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7 col-xl-6 col-md-8">
      <!-- Enhanced Card with Large Shadow -->
      <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <!-- Optional gradient header -->
        <div class="bg-gradient text-white py-4 rounded-top-4" 
             style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
          <h2 class="text-center text-dark fw-bold mb-0">
            <i class="fas fa-edit me-2"></i>Edit Listing
          </h2>
        </div>
        
        <div class="card-body p-4 p-lg-5">
          <form method="POST"
                action="/listings/<%= listing._id %>?_method=PUT"
                novalidate
                class="needs-validation"
                enctype="multipart/form-data">
            
            <!-- Title with Floating Label -->
            <div class="mb-4">
              <div class="form-floating">
                <input name="listing[title]"
                       class="form-control form-control-lg"
                       id="titleInput"
                       value="<%= listing.title %>"
                       type="text"
                       required>
                <label for="titleInput" class="form-label fw-semibold">Listing Title</label>
              </div>
            </div>

            <!-- Description -->
            <div class="mb-4">
              <div class="form-floating">
                <textarea name="listing[description]"
                          class="form-control"
                          id="descInput"
                          rows="4"
                          style="min-height: 120px;"
                          required><%= listing.description %></textarea>
                <label for="descInput" class="form-label fw-semibold">Description</label>
              </div>
            </div>

            <!-- Image Preview & Upload -->
            <div class="mb-4">
              <label class="form-label fw-semibold mb-3 d-block">
                <i class="fas fa-image me-1"></i>Current Image
              </label>
              <div class="text-center mb-3">
                <img src="<%= originalImageUrl %>" 
                     alt="Current listing image"
                     class="img-fluid rounded-3 shadow-sm"
                     style="max-height: 200px; width: 100%; object-fit: cover;">
              </div>
              
              <div class="form-floating">
                <input name="listing[image]"
                       class="form-control"
                       id="imageInput"
                       type="file"
                       accept="image/*">
                <label for="imageInput" class="form-label fw-semibold">Upload New Image</label>
              </div>
            </div>

            <!-- Price & Country Row -->
            <div class="row g-4 mb-4">
              <div class="col-md-5">
                <div class="form-floating">
                  <input name="listing[price]"
                         class="form-control form-control-lg"
                         id="priceInput"
                         value="<%= listing.price %>"
                         type="number"
                         min="0"
                         step="0.01"
                         required>
                  <label for="priceInput" class="form-label fw-semibold">$ Price/Night</label>
                </div>
              </div>
              <div class="col-md-7">
                <div class="form-floating">
                  <input name="listing[country]"
                         class="form-control form-control-lg"
                         id="countryInput"
                         value="<%= listing.country %>"
                         type="text"
                         required>
                  <label for="countryInput" class="form-label fw-semibold">Country</label>
                </div>
              </div>
            </div>

            <!-- Location -->
            <div class="mb-5">
              <div class="form-floating">
                <input name="listing[location]"
                       class="form-control form-control-lg"
                       id="locationInput"
                       value="<%= listing.location %>"
                       type="text"
                       required>
                <label for="locationInput" class="form-label fw-semibold">Location (City/Area)</label>
              </div>
            </div>

            <!-- Enhanced Submit Button -->
            <div class="d-grid">
              <button type="submit" 
                      class="btn btn-dark btn-lg rounded-pill px-5 py-3 shadow-lg"
                      style="border: none;
                             font-weight: 600;
                             font-size: 1.1rem;
                             transition: all 0.3s ease;">
                <i class="fas fa-save me-2"></i>Update Listing
              </button>
            </div>

            <!-- Optional: Cancel link -->
            <div class="text-center mt-3">
              <a href="/listings/<%= listing._id %>" 
                 class="text-muted text-decoration-none fw-semibold">
                <i class="fas fa-arrow-left me-1"></i>Cancel & View Listing
              </a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Bootstrap Validation JS (keep at bottom) -->
<script>
(function() {
  'use strict'
  var forms = document.querySelectorAll('.needs-validation')
  Array.prototype.slice.call(forms)
    .forEach(function (form) {
      form.addEventListener('submit', function (event) {
        if (!form.checkValidity()) {
          event.preventDefault()
          event.stopPropagation()
        }
        form.classList.add('was-validated')
      }, false)
    })
})()
</script>

<style>
/* Custom enhancements */
.form-floating > .form-control:focus ~ label,
.form-floating > .form-control:not(:placeholder-shown) ~ label {
  color: #0b0c0b;
  font-weight: 600;
}

.btn:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 25px rgba(4, 13, 29, 0.5) !important;
}

.card {
  backdrop-filter: blur(20px);
  background: rgba(255,255,255,0.95);
}

.img-fluid {
  transition: transform 0.3s ease;
}

.img-fluid:hover {
  transform: scale(1.02);
}
</style>