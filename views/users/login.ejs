<% layout("/layouts/boilerplate") %>

<div class="container d-flex align-items-center justify-content-center" style="min-height: 90vh;">

  <div class="card shadow-lg border-0 rounded-4 p-4" style="width: 100%; max-width: 420px;">


<!-- Header -->
<div class="text-center mb-4">
  <h2 class="fw-bold">Login</h2><hr class="my-4 w-75 mx-auto rounded-pill" 
     style="height: 2px; background: linear-gradient(90deg, #0e0f0e, #070707, #000000); border: none;">
</div>

<!-- Form -->
<form action="/login" method="POST" class="needs-validation" novalidate>

  <%- include("../includes/auth_fields.ejs", { 
    showEmail: false, 
    showPasswordInstructions: false,
    errors: errors,
    formData: formData
  }) %>

  <% if (errors.general) { %>
    <div class="alert alert-danger py-2 mb-3" role="alert">
      <%= errors.general %>
    </div>
  <% } %>

  <!-- Remember + Forgot -->
  <div class="d-flex justify-content-between align-items-center mb-3">
    <div class="form-check">
      <input class="form-check-input" type="checkbox" id="remember">
      <label class="form-check-label" for="remember">
        Remember me
      </label>
    </div>
    <a href="#" class="text-decoration-none small">Forgot password?</a>
  </div>

  <!-- Button -->
  <div class="d-grid mt-4">
    <button class="btn btn-success btn-lg rounded-3">
      Login
    </button>
  </div>

</form>



<!-- Footer -->
<div class="text-center mt-3">
  <small class="text-muted">
    Don't have an account? 
    <a href="/signup" class="text-decoration-none">Sign Up</a>
  </small>
</div>


  </div>

</div>
