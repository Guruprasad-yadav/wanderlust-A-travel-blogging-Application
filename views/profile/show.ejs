<% layout("/layouts/boilerplate") %>

<style>
    body {
        background: #f4f7fb;
    }

    .profile-container {
        min-height: 90vh;
        padding: 60px 0;
    }

    .profile-card {
        background: #fff;
        border-radius: 25px;
        padding: 45px 35px;
        box-shadow:
            0 10px 30px rgba(0, 0, 0, 0.08),
            0 4px 12px rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease;
        border: 1px solid #f1f1f1;
    }

    .profile-card:hover {
        transform: translateY(-5px);
        box-shadow:
            0 18px 40px rgba(0, 0, 0, 0.12),
            0 6px 16px rgba(0, 0, 0, 0.08);
    }

    .profile-img-container {
        width: 160px;
        height: 160px;
        margin: auto;
        position: relative;
    }

    .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        border-radius: 50%;
        border: 5px solid #fff;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
    }

    .profile-name {
        font-size: 2rem;
        font-weight: 700;
        color: #212529;
    }

    .username {
        color: #6c757d;
        font-size: 1rem;
    }

    .stats-card {
        background: #fff;
        border-radius: 18px;
        padding: 20px;
        text-align: center;
        box-shadow:
            0 6px 18px rgba(0,0,0,0.06);
        transition: 0.3s ease;
        border: 1px solid #f2f2f2;
    }

    .stats-card:hover {
        transform: translateY(-3px);
    }

    .stats-value {
        font-size: 1.8rem;
        font-weight: 700;
        color: #fe424d;
    }

    .stats-label {
        font-size: 0.85rem;
        color: #6c757d;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .section-box {
        background: #fff;
        border-radius: 18px;
        padding: 20px;
        box-shadow:
            0 5px 15px rgba(0,0,0,0.05);
        margin-bottom: 20px;
        border: 1px solid #f2f2f2;
    }

    .info-item {
        display: flex;
        align-items: center;
        gap: 15px;
        padding: 14px 0;
        border-bottom: 1px solid #f1f1f1;
    }

    .info-item:last-child {
        border-bottom: none;
    }

    .info-icon {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #fe424d, #ff6b75);
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        box-shadow: 0 4px 12px rgba(254, 66, 77, 0.3);
    }

    .edit-btn {
        background: linear-gradient(135deg, #fe424d, #ff6b75);
        color: white;
        border: none;
        padding: 12px 32px;
        border-radius: 50px;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.3s ease;
        display: inline-block;
        box-shadow: 0 8px 20px rgba(254, 66, 77, 0.25);
    }

    .edit-btn:hover {
        transform: translateY(-2px) scale(1.03);
        color: white;
        box-shadow: 0 12px 24px rgba(254, 66, 77, 0.35);
    }

    .joined-date {
        color: #868e96;
        font-size: 0.9rem;
        margin-top: 25px;
    }

    .about-text {
        color: #495057;
        line-height: 1.7;
    }

    @media(max-width: 768px) {
        .profile-card {
            padding: 30px 20px;
        }

        .profile-name {
            font-size: 1.6rem;
        }
    }
</style>

<div class="profile-container">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8 col-md-10">

                <div class="profile-card">

                    <!-- Profile Image -->
                    <div class="text-center mb-4">
                        <div class="profile-img-container">
                            <img 
                                src="<%= (user.profileImage && user.profileImage.url) ? user.profileImage.url : 'https://res.cloudinary.com/dmpp9f0v5/image/upload/v1716024194/default_avatar_qf6qzv.png' %>" 
                                alt="Profile Image" 
                                class="profile-img"
                            >
                        </div>

                        <h2 class="profile-name mt-3">
                            <%= user.fullName || user.username %>
                        </h2>

                        <p class="username">
                            @<%= user.username %>
                        </p>
                    </div>

                    <!-- Stats -->
                    <div class="row g-4 mb-4">
                        <div class="col-6">
                            <div class="stats-card">
                                <div class="stats-value">
                                    <%= totalListings %>
                                </div>
                                <div class="stats-label">
                                    Listings
                                </div>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="stats-card">
                                <div class="stats-value">
                                    <%= totalReviews %>
                                </div>
                                <div class="stats-label">
                                    Reviews
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- About -->
                    <% if(user.bio) { %>
                        <div class="section-box">
                            <h6 class="fw-bold text-uppercase text-muted mb-3">
                                About Me
                            </h6>

                            <p class="about-text mb-0">
                                <%= user.bio %>
                            </p>
                        </div>
                    <% } %>

                    <!-- User Info -->
                    <div class="section-box">

                        <div class="info-item">
                            <div class="info-icon">
                                <i class="fa-solid fa-envelope"></i>
                            </div>

                            <div>
                                <div class="small text-muted">
                                    Email
                                </div>

                                <div class="fw-semibold small text-break">
                                    <%= user.email %>
                                </div>
                            </div>
                        </div>

                        <% if(user.location) { %>
                            <div class="info-item">
                                <div class="info-icon">
                                    <i class="fa-solid fa-location-dot"></i>
                                </div>

                                <div>
                                    <div class="small text-muted">
                                        Location
                                    </div>

                                    <div class="fw-semibold">
                                        <%= user.location %>
                                    </div>
                                </div>
                            </div>
                        <% } %>

                        <% if(user.phone) { %>
                            <div class="info-item">
                                <div class="info-icon">
                                    <i class="fa-solid fa-phone"></i>
                                </div>

                                <div>
                                    <div class="small text-muted">
                                        Phone
                                    </div>

                                    <div class="fw-semibold">
                                        <%= user.phone %>
                                    </div>
                                </div>
                            </div>
                        <% } %>

                    </div>

                    <!-- Button -->
                    <div class="text-center mt-4">
                        <a href="/profile/edit" class="edit-btn">
                            <i class="fa-solid fa-pen-to-square me-2"></i>
                            Edit Profile
                        </a>
                    </div>

                    <!-- Joined Date -->
                    <div class="text-center joined-date">
                        Joined on
                        <%= new Date(user.joinedAt).toLocaleDateString('en-US', {
                            year: 'numeric',
                            month: 'long',
                            day: 'numeric'
                        }) %>
                    </div>

                </div>

            </div>
        </div>
    </div>
</div>